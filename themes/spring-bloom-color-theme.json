  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment", "comment.line", "comment.block"],
      "settings": {
        "foreground": "#B8909A",
        "fontStyle": "italic"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted",
        "string.quoted.single",
        "string.quoted.double",
        "string.quoted.triple",
        "string.unquoted",
        "meta.embedded.assembly"
      ],
      "settings": {
        "foreground": "#4A8C2A"
      }
    },
    {
      "name": "String escape / regex special",
      "scope": [
        "constant.character.escape",
        "constant.character.string.escape",
        "constant.regexp",
        "keyword.other.back-reference.regexp",
        "keyword.operator.quantifier.regexp",
        "punctuation.definition.group.regexp",
        "punctuation.definition.character-class.regexp",
        "punctuation.definition.group.assertion.regexp"
      ],
      "settings": {
        "foreground": "#5FAE35"
      }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.other",
        "storage.type.function",
        "storage.modifier.async"
      ],
      "settings": {
        "foreground": "#C4527A",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Storage / declarations",
      "scope": [
        "storage.type",
        "storage.modifier",
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from",
        "keyword.control.default"
      ],
      "settings": {
        "foreground": "#C4527A",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Operator",
      "scope": [
        "keyword.operator",
        "keyword.operator.logical",
        "keyword.operator.arithmetic",
        "keyword.operator.comparison",
        "keyword.operator.assignment",
        "keyword.operator.increment",
        "keyword.operator.decrement",
        "keyword.operator.bitwise",
        "keyword.operator.channel",
        "keyword.operator.relational"
      ],
      "settings": {
        "foreground": "#C4608A"
      }
    },
    {
      "name": "Variable",
      "scope": ["variable", "variable.other", "variable.language"],
      "settings": {
        "foreground": "#2D1A0E"
      }
    },
    {
      "name": "Parameter",
      "scope": ["variable.parameter", "meta.function.parameters"],
      "settings": {
        "foreground": "#7A5A48",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Function / method",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "meta.method-call"
      ],
      "settings": {
        "foreground": "#5C3A1E"
      }
    },
    {
      "name": "Class / type / interface / enum",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.interface",
        "entity.name.enum",
        "support.type",
        "support.class",
        "entity.other.inherited-class",
        "meta.type.annotation"
      ],
      "settings": {
        "foreground": "#3A8CC4"
      }
    },
    {
      "name": "Built-in constants / booleans",
      "scope": [
        "constant.language",
        "constant.language.null",
        "constant.language.undefined",
        "constant.language.boolean",
        "constant.language.nan"
      ],
      "settings": {
        "foreground": "#B07A10",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Number",
      "scope": ["constant.numeric", "constant.numeric.integer", "constant.numeric.float"],
      "settings": {
        "foreground": "#B07A10"
      }
    },
    {
      "name": "Decorator / annotation",
      "scope": [
        "meta.decorator",
        "punctuation.decorator",
        "support.decorator",
        "entity.name.function.decorator"
      ],
      "settings": {
        "foreground": "#C4527A",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Invalid / error",
      "scope": ["invalid", "invalid.illegal"],
      "settings": {
        "foreground": "#CC2244",
        "fontStyle": "underline"
      }
    },
    {
      "name": "HTML / XML tag name",
      "scope": [
        "entity.name.tag",
        "entity.name.tag.localname",
        "entity.name.tag.namespace"
      ],
      "settings": {
        "foreground": "#C4527A"
      }
    },
    {
      "name": "HTML / XML attribute name",
      "scope": ["entity.other.attribute-name", "entity.other.attribute-name.localname"],
      "settings": {
        "foreground": "#5C3A1E"
      }
    },
    {
      "name": "HTML / XML punctuation",
      "scope": [
        "punctuation.definition.tag",
        "meta.tag punctuation.definition.tag",
        "punctuation.separator.namespace.xml"
      ],
      "settings": {
        "foreground": "#B89888"
      }
    },
    {
      "name": "CSS / SCSS selectors",
      "scope": [
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css",
        "entity.name.tag.css",
        "entity.other.attribute-name.pseudo-class.css",
        "entity.other.attribute-name.pseudo-element.css"
      ],
      "settings": {
        "foreground": "#3A8CC4"
      }
    },
    {
      "name": "CSS property name",
      "scope": ["support.type.property-name.css", "support.type.property-name.scss"],
      "settings": {
        "foreground": "#5C3A1E"
      }
    },
    {
      "name": "CSS property value keyword",
      "scope": ["support.constant.property-value.css", "support.constant.color.w3c-standard-color-name.css"],
      "settings": {
        "foreground": "#4A8C2A"
      }
    },
    {
      "name": "JSON / YAML / TOML keys",
      "scope": [
        "support.type.property-name.json",
        "entity.name.tag.yaml",
        "entity.name.tag.toml"
      ],
      "settings": {
        "foreground": "#C4527A"
      }
    },
    {
      "name": "Markdown heading",
      "scope": ["markup.heading", "markup.heading.markdown"],
      "settings": {
        "foreground": "#2D1A0E",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown heading marker",
      "scope": ["punctuation.definition.heading.markdown"],
      "settings": {
        "foreground": "#C4527A"
      }
    },
    {
      "name": "Markdown emphasis italic",
      "scope": ["markup.italic.markdown"],
      "settings": {
        "foreground": "#5C3A1E",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown strong",
      "scope": ["markup.bold.markdown"],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown link",
      "scope": ["markup.underline.link.markdown", "string.other.link.title.markdown"],
      "settings": {
        "foreground": "#3A8CC4"
      }
    },
    {
      "name": "Markdown inline / fenced code",
      "scope": [
        "markup.inline.raw.markdown",
        "markup.raw.block.markdown",
        "markup.fenced_code.block.markdown"
      ],
      "settings": {
        "foreground": "#5C3A1E",
        "background": "#F1E6DF"
      }
    },
    {
      "name": "Import path",
      "scope": ["string.quoted.module"],
      "settings": {
        "foreground": "#3A8CC4"
      }
    }
  ],
  "semanticTokenColors": {
    "keyword": { "foreground": "#C4527A", "fontStyle": "bold" },
    "modifier": { "foreground": "#C4527A", "fontStyle": "bold" },
    "namespace": "#3A8CC4",
