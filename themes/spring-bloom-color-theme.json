    "variable": "#2D1A0E",
    "property": "#5C3A1E",
    "enumMember": "#B07A10",
    "decorator": { "foreground": "#C4527A", "fontStyle": "italic" },
    "event": "#5C3A1E",
    "function": "#5C3A1E",
    "method": "#5C3A1E",
    "macro": "#5C3A1E",
    "label": "#C4527A",
    "comment": { "foreground": "#B8909A", "fontStyle": "italic" },
    "string": "#4A8C2A",
    "number": "#B07A10",
    "regexp": "#5FAE35",
    "operator": "#C4608A",
    "variable.readonly": "#7A5A48",
    "variable.defaultLibrary": { "foreground": "#B07A10", "fontStyle": "bold" },
    "property.readonly": "#7A5A48",
    "function.defaultLibrary": { "foreground": "#B07A10", "fontStyle": "bold" },
    "method.defaultLibrary": { "foreground": "#B07A10", "fontStyle": "bold" },
    "class.defaultLibrary": "#3A8CC4",
    "interface.defaultLibrary": "#3A8CC4",
    "type.defaultLibrary": "#3A8CC4",
    "namespace.defaultLibrary": "#3A8CC4",
    "class.declaration": "#3A8CC4",
    "interface.declaration": "#3A8CC4",
    "function.declaration": "#5C3A1E",
    "method.declaration": "#5C3A1E",
